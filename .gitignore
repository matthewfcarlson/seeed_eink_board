# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# PlatformIO build artifacts
.pio/

# Config file with credentials (use config.h.example as template)
config.h

# User images (users provide their own)
*.jpg
*.jpeg
*.png
*.JPG
*.JPEG
*.PNG

# ...except the worker's contract-test fixtures, which must be checked in for
# the dual-run test harness to be reproducible on a fresh clone.
!worker/test/contract/fixtures/images/**/*.jpg
!worker/test/contract/fixtures/images/**/*.jpeg
!worker/test/contract/fixtures/images/**/*.png

# Node / Cloudflare Workers (worker/)
worker/node_modules/
worker/.wrangler/
worker/.dev.vars

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Image server state
.eink_rotation_state.json
