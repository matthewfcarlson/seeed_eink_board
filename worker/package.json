{
  "name": "eink-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "node scripts/build-client.mjs",
    "predev": "wrangler d1 migrations apply eink-local --local --env local && npm run build:client",
    "dev": "wrangler dev --env local",
    "predeploy": "npm run build:client",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json && tsc --noEmit -p src/client/tsconfig.json",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply eink-local --local --env local",
    "db:migrate:remote": "wrangler d1 migrations apply eink --remote"
  },
  "dependencies": {
    "@cf-wasm/photon": "^0.3.6",
    "@simplewebauthn/server": "^13.3.2",
    "hono": "^4.6.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
