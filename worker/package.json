{
  "name": "eink-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply eink-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply eink-db --remote"
  },
  "dependencies": {
    "@cf-wasm/photon": "^0.3.6",
    "hono": "^4.6.0",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/node": "^26.1.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
